% theorems environments
\declaretheoremstyle[
  bodyfont=\normalfont,
  numberwithin=section,
]{basic}
\declaretheorem[
  name=Remark,
  style=basic,
  shaded={
    bgcolor=cornsilk,
    textwidth=0.9725\textwidth,
    padding=6.7pt,
  },
]{remark}
\declaretheorem[
  name=Exercise,
  style=basic,
  shaded={
    bgcolor=teagreen,
    textwidth=0.9725\textwidth,
    padding=6.7pt,
  },
  ]{exercise}
\declaretheorem[
  name=Notation,
  style=basic,
  shaded={
    textwidth=0.9725\textwidth,
    padding=6.7pt,
  },
]{notation}
\declaretheorem[
  name=Example,
  style=basic,
  shaded={
    textwidth=0.9725\textwidth,
    padding=6.7pt,
  },
]{example}
\declaretheorem[
  name=Definition,
  style=basic,
  shaded={
    bgcolor=lavendermist,
    textwidth=0.9725\textwidth,
    padding=6.7pt,
  },
]{definition}
\declaretheorem[
  name=Theorem,
  style=basic,
  shaded={
    bgcolor=piggypink,
    textwidth=0.9725\textwidth,
    padding=6.7pt,
  },
]{theorem}
\declaretheorem[
  name=Proposition,
  style=basic,
  shaded={
    bgcolor=piggypink,
    textwidth=0.9725\textwidth,
    padding=6.7pt,
  },
]{proposition}

